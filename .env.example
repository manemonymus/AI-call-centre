# Copy this file to .env and fill in your keys. .env is gitignored.
# services.py loads it automatically on startup.

# --- The Deepgram + Claude production stack ---
# Deepgram: sign up at console.deepgram.com (new accounts get free credit).
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_deepgram_key_here

# Anthropic: get a key at console.anthropic.com
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Optional overrides (defaults shown) ---
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# DEEPGRAM_MODEL=nova-3-general
# DEEPGRAM_MIP_OPT_OUT=true        # keep caller audio out of Deepgram training
# COMPANY_NAME=Hearthstone Home Services
# ENABLE_RAG=true

# --- Fall back to the free local stack ---
# STT_PROVIDER=whisper
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5
# WHISPER_MODEL=small

# --- Twilio (server.py only) ---
# PUBLIC_HOSTNAME=your-id.ngrok.io
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
